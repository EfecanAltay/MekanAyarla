generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = "postgresql://postgres:postgres@localhost:5433/bosyervarmi?schema=public"
}

enum UserRole {
  SUPER_ADMIN
  BUSINESS_ADMIN
  STAFF
  CUSTOMER
}

enum ReservationStatus {
  PENDING
  CONFIRMED
  CANCELLED
  ATTENDED
  NOSHOW
}

enum WaitlistStatus {
  WAITING
  PROMOTED
  CANCELLED
}

model User {
  id             String        @id @default(uuid())
  email          String        @unique
  password       String
  name           String
  role           UserRole      @default(CUSTOMER)
  organizationId String?
  organization   Organization? @relation(fields: [organizationId], references: [id])
  reservations   Reservation[]
  waitlist       Waitlist[]
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt
}

model Organization {
  id            String          @id @default(uuid())
  name          String
  branches      Branch[]
  resourceTypes ResourceType[]
  users         User[]
  policies      BookingPolicy[]
  createdAt     DateTime        @default(now())
  updatedAt     DateTime        @updatedAt
}

model Branch {
  id             String       @id @default(uuid())
  name           String
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id])
  resources      Resource[]
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt
}

model ResourceType {
  id             String       @id @default(uuid())
  name           String
  description    String?
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id])
  resources      Resource[]
  config         Json? // Dynamic config per resource type
  createdAt      DateTime     @default(now())
}

model Resource {
  id           String       @id @default(uuid())
  name         String
  description  String?
  typeId       String
  type         ResourceType @relation(fields: [typeId], references: [id])
  branchId     String
  branch       Branch       @relation(fields: [branchId], references: [id])
  capacity     Int          @default(1)
  startDate    DateTime?
  endDate      DateTime?
  startTime    String?
  endTime      String?
  slotDuration Int?
  active       Boolean      @default(true)
  offDays      Int[]        @default([])
  offHours     String[]     @default([])
  slots        TimeSlot[]
  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt
}

model TimeSlot {
  id           String        @id @default(uuid())
  resourceId   String
  resource     Resource      @relation(fields: [resourceId], references: [id])
  startTime    DateTime
  endTime      DateTime
  capacity     Int? // Override resource capacity
  isAvailable  Boolean       @default(true)
  note         String?
  reservations Reservation[]
  waitlist     Waitlist[]
  createdAt    DateTime      @default(now())

  @@index([startTime])
  @@index([resourceId])
}

model Reservation {
  id         String            @id @default(uuid())
  userId     String
  user       User              @relation(fields: [userId], references: [id])
  timeSlotId String
  timeSlot   TimeSlot          @relation(fields: [timeSlotId], references: [id])
  status     ReservationStatus @default(PENDING)
  notes      String?
  metadata   Json?
  createdAt  DateTime          @default(now())
  updatedAt  DateTime          @updatedAt

  @@unique([userId, timeSlotId]) // Prevent duplicate bookings for same slot
}

model Waitlist {
  id         String         @id @default(uuid())
  userId     String
  user       User           @relation(fields: [userId], references: [id])
  timeSlotId String
  timeSlot   TimeSlot       @relation(fields: [timeSlotId], references: [id])
  status     WaitlistStatus @default(WAITING)
  position   Int
  createdAt  DateTime       @default(now())

  @@unique([userId, timeSlotId])
}

model BookingPolicy {
  id                   String       @id @default(uuid())
  organizationId       String
  organization         Organization @relation(fields: [organizationId], references: [id])
  maxBookingsPerUser   Int?
  cancellationDeadline Int? // In hours
  autoConfirm          Boolean      @default(true)
  allowWaitlist        Boolean      @default(true)
  createdAt            DateTime     @default(now())
}
